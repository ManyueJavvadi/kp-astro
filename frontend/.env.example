# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# App environment (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# PostHog (optional — leave unset in dev)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional — leave unset in dev)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/zzzzz
# SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/zzzzz
# SENTRY_ORG=your-org
# SENTRY_PROJECT=devastroai-web
# SENTRY_AUTH_TOKEN=sntrys_...
