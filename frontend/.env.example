# DevAstroAI frontend env vars.
# Last updated 2026-06-08 (Step 1: dev/prod separation).
#
# For LOCAL DEV: copy to frontend/.env.local and fill in.
# For STAGING:   set in Vercel dashboard → "Preview" scope.
# For PROD:      set in Vercel dashboard → "Production" scope.
# NEVER commit .env.local.
#
# NEXT_PUBLIC_* vars are inlined at BUILD TIME and visible in the
# browser bundle. ONLY put genuinely-public values here (URLs, anon
# keys designed for client use). Never the JWT secret or service_role
# key — those stay on the backend.
#
# See DEPLOYMENT.md at the repo root for which values change per env.

# ─── Environment tag ──────────────────────────────────────────────
# One of: development | staging | production
# Used to show a small "STAGING" banner on non-prod builds so you can
# never confuse the two browser tabs.
NEXT_PUBLIC_ENV=development

# ─── Backend ──────────────────────────────────────────────────────
# The Railway backend URL for this env.
# Staging: https://devastroai-staging.up.railway.app  (or similar)
# Prod:    https://devastroai.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Site URL (for OG cards, canonical links, email links) ────────
# Staging: https://staging.devastroai.com
# Prod:    https://devastroai.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase Auth (ADR-002) ──────────────────────────────────────
# Supabase Dashboard → Settings → API.
# STAGING + PROD must use SEPARATE Supabase projects (see backend
# .env.example for the same warning).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# "anon" "public" key — designed to be exposed in browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx...
# Newer Supabase projects expose a "publishable" key instead of/in
# addition to anon. Set whichever your project uses; code falls back.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# ─── PostHog (product analytics — Step 2, coming next after dev/prod) ──
# Get from PostHog → Project Settings → Project API Key.
# Use separate keys for staging vs prod to keep analytics data clean.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
