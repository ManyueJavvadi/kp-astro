# DevAstroAI frontend env vars — Phase 1 (2026-06-01).
#
# For local dev: copy this file to frontend/.env.local and fill values.
# For production: set in Vercel dashboard → Settings → Environment Variables.
# NEVER commit .env.local.
#
# NEXT_PUBLIC_* vars are inlined at build time and visible in the
# browser bundle. ONLY put genuinely-public values here (URLs, anon
# keys designed for client use). Never the JWT secret or service_role
# key — those stay on the backend.
#
# See SETUP-PHASE-1.md for where to get each value.

# ─── Backend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://devastroai.up.railway.app

# ─── Supabase Auth (ADR-002) ──────────────────────────────────────
# Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Project API keys → "anon" "public" — designed to be exposed in browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx...
