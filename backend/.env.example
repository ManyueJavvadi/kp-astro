# DevAstroAI backend env vars.
# Last updated 2026-06-08 (Step 1: dev/prod separation).
#
# For LOCAL DEV: copy to backend/.env and fill in.
# For STAGING:   set in Railway dashboard → backend-staging service.
# For PROD:      set in Railway dashboard → backend service.
# NEVER commit a populated .env.
#
# See DEPLOYMENT.md at the repo root for which values change per env.

# ─── Runtime ──────────────────────────────────────────────────────
# One of: development | staging | production
# Affects Sentry environment tagging and lets /version identify env.
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Database (ADR-001) ───────────────────────────────────────────
# Railway auto-injects this when the Postgres add-on is attached.
# For local dev: use a local Postgres OR copy the Railway URL here
# (don't run heavy migrations against shared DB).
#
# STAGING and PROD must use SEPARATE Postgres add-ons. Sharing the DB
# defeats the entire point of having separate envs.
DATABASE_URL=postgresql://postgres:password@localhost:5432/devastroai

# ─── Supabase Auth (ADR-002) ──────────────────────────────────────
# Get from Supabase Dashboard → Settings → API.
#
# STAGING and PROD must use SEPARATE Supabase projects. Test signups
# on staging must NOT land in the prod user table.
SUPABASE_URL=https://your-project.supabase.co
# JWT Settings → JWT Secret (NOT the anon or service_role key).
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── AI ───────────────────────────────────────────────────────────
# Same Anthropic key can be used across staging + prod — Anthropic
# bills per request, and we want staging to exercise the real API.
ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── Frontend URL (for CORS allow-list + future redirects) ────────
# Staging: https://staging.devastroai.com
# Prod:    https://devastroai.com
FRONTEND_URL=http://localhost:3000

# ─── CORS / rate limiting (optional overrides) ────────────────────
# Comma-separated list. Defaults in main.py cover prod + local dev.
# CORS_ALLOWED_ORIGINS=https://devastroai.com,https://staging.devastroai.com,http://localhost:3000
# Regex for wildcard match (Vercel preview URLs by default).
# CORS_ALLOWED_ORIGIN_REGEX=https://([a-z0-9-]+\.)*vercel\.app
# MAX_REQUEST_BODY_BYTES=262144
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_MAX_KEYS=10000

# ─── Sentry (error tracking) ──────────────────────────────────────
# Optional but recommended for staging + prod. Get DSN from
# Sentry → Settings → Projects → Client Keys.
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT defaults to ENVIRONMENT value if not set.
# SENTRY_ENVIRONMENT=staging
# Sample rate for performance traces (0.0–1.0). Lower in prod for cost.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Admin debug endpoints ────────────────────────────────────────
# When set, /version/full requires X-Admin-Token header matching this.
# Leave unset to disable the endpoint entirely.
# ADMIN_DEBUG_TOKEN=some-long-random-string
