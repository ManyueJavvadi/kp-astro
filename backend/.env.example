# DevAstroAI backend env vars — Phase 1 (2026-06-01).
#
# For local dev: copy this file to backend/.env and fill in values.
# For production: set these in the Railway dashboard for the backend
#                 service. NEVER commit a populated .env.
#
# See SETUP-PHASE-1.md for where to get each value.

# ─── Runtime ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Database (ADR-001) ───────────────────────────────────────────
# Railway auto-injects this when the Postgres add-on is attached.
# For local dev: use a local Postgres OR copy the Railway URL here
# (don't run heavy migrations against shared DB).
DATABASE_URL=postgresql://postgres:password@localhost:5432/devastroai

# ─── Supabase Auth (ADR-002) ──────────────────────────────────────
# Get from Supabase Dashboard → Settings → API.
SUPABASE_URL=https://your-project.supabase.co
# JWT Settings → JWT Secret (NOT the anon or service_role key).
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── CORS / rate limiting (optional overrides) ────────────────────
# Comma-separated list. Defaults in main.py cover prod + local dev.
# CORS_ALLOWED_ORIGINS=https://devastroai.com,http://localhost:3000
# Regex for wildcard match (Vercel preview URLs by default).
# CORS_ALLOWED_ORIGIN_REGEX=https://([a-z0-9-]+\.)*vercel\.app
# MAX_REQUEST_BODY_BYTES=262144
# RATE_LIMIT_ENABLED=1
